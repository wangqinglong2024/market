      "transitionIn": "slide-left",
      "captions": {
        "pinyin": "jièzhù chē mǎ de rén, jiǎo lì zài pǔtōng, yě néng rì xíng qiān lǐ.",
        "zh": "借助车马的人，脚力再普通，也能日行千里。",
        "local": "Nhờ xe ngựa, dù sức thường, vẫn đi ngàn dặm mỗi ngày."
      }
    },
    {
      "id": "p4",
