      "motion": "pan-left",
      "transitionIn": "fade",
      "captions": {
        "pinyin": "jièzhù chuán zhī de rén, jíshǐ bù huì yóuyǒng, yě néng dùguò dà jiāng.",
        "zh": "借助船只的人，即使不会游泳，也能渡过大江。",
        "local": "Nhờ con thuyền, dù không biết bơi, vẫn qua được sông sâu."
      }
    },
